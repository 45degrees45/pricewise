# Telegram Bot
TELEGRAM_TOKEN=your_telegram_bot_token
ALLOWED_USER_IDS=123456789,987654321  # comma-separated, leave empty for no restriction

# Google Sheets
OAUTH_CREDENTIALS_PATH=oauth_credentials.json
SHEETS_ID=your_google_sheets_id

# Anthropic (optional – leave empty to use Ollama instead)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Ollama (local fallback when Anthropic key is not set)
OLLAMA_MODEL=llama3.2
